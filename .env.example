# Parâmetros específicos do ambiente — copie para `.env` e preencha.
# O `.env` NÃO é versionado (ver .gitignore); este arquivo é apenas o modelo.

# IP fixo do notebook na rede local (reserva DHCP) e porta do servidor Flask
NOTEBOOK_IP=192.168.0.100
SERVER_PORT=5000

# Skill Alexa "Voice Monkey" (Fase 3) — API v3, device do tipo Speaker
VOICEMONKEY_TOKEN=
VOICEMONKEY_DEVICE_ID=

# Serviço de push para vibração no smartwatch (Fase 4)
NTFY_TOPIC_URL=
PUSHOVER_TOKEN=
PUSHOVER_USER=
